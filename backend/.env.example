DISCORD_BOT_TOKEN=
# Discord: grant/remove "at HILab" role from LAN presence (users with discordId in users.json)DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Optional: exact role snowflake (recommended). If empty, role is found by name below.
DISCORD_AT_HILAB_ROLE_ID=
# Used when DISCORD_AT_HILAB_ROLE_ID is not set (must match server role name exactly)
DISCORD_AT_HILAB_ROLE_NAME=at HILab

# Optional: LAN scan tuning (users without discordId)
# SCAN_INTERVAL_MS=30000
# SCANS_PER_WINDOW=6
# PRESENCE_THRESHOLD=1
# LOG_PRESENCE=true